# Copy to .env for local runs. In GitHub Actions, use repository Secrets / Variables.

# Required for Groq failover (recommended: keep set in CI).
# Keys: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq model id (default: llama-3.3-70b-versatile). See deprecations:
# https://console.groq.com/docs/deprecations
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: primary provider when set — tried before Groq.
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# Optional Anthropic model id (default: claude-opus-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6
